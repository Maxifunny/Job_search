# =============================================================================
# Job Search — konfiguracja pod Google Gemini API (Google AI Studio, free tier)
# =============================================================================
#
# Jak użyć:
#   cp .env.gemini.example .env
#   # Wklej swój klucz z https://aistudio.google.com/apikey
#
# Klucz API generujesz w Google AI Studio (to samo konto Google co Gemini).
# Studenckie konto Gemini (apka) ≠ klucz API — potrzebujesz osobno API key z AI Studio.
#
# =============================================================================

# --- Aplikacja ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Baza relacyjna (lokalna, bez klucza) ---
DATABASE_URL=sqlite:///./data/job_search.db

# --- ChromaDB — baza wektorowa (lokalna, bez klucza) ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_OFFERS=job_offers
CHROMA_COLLECTION_PREFERENCES=user_preferences

# --- Gemini API (OpenAI-compatible endpoint) ---
# Klucz: https://aistudio.google.com/apikey  (format AIza...)
LLM_API_KEY=

# Oficjalny endpoint Gemini kompatybilny z biblioteką openai
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Modele na free tier — wystarczają do matchingu ofert pracy
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001

# --- Progi dopasowania (możesz dostroić później) ---
MIN_SEMANTIC_SCORE=0.65
MIN_LLM_CONFIDENCE=0.70

# --- Scraper (JustJoin.it — publiczne API, bez klucza) ---
SCRAPER_USER_AGENT=JobSearchBot/1.0 (+https://github.com/Maxifunny/Job_search)
SCRAPER_REQUEST_DELAY_SECONDS=2
JUSTJOIN_API_BASE=https://justjoin.it/api
