# =============================================================================
# Job Search — konfiguracja EC2 (AWS)
# =============================================================================
# Skopiuj na serwer:
#   cp infra/aws/env.ec2.example .env
#   nano .env
#
# Sekrety trzymaj tylko na serwerze — nie commituj .env do git.
# =============================================================================

APP_ENV=production
LOG_LEVEL=INFO

# Baza i Chroma — lokalnie na dysku EC2 (EBS)
DATABASE_URL=sqlite:///./data/job_search.db
CHROMA_PERSIST_DIR=./data/chroma

# --- Gemini / LLM (Google AI Studio) ---
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash
LLM_FALLBACK_MODELS=gemini-2.0-flash,gemini-1.5-flash,gemini-2.5-flash-lite
LLM_RETRY_ATTEMPTS=2
EMBEDDING_MODEL=gemini-embedding-001

# --- Parametry dziennego runu (używane przez run_daily_pipeline.sh) ---
JOB_SEARCH_SECTOR=data
JOB_SEARCH_PROFILE=config/profiles/default.json
JOB_SEARCH_SOURCE=justjoin
JOB_SEARCH_MAX_OFFERS=30
JOB_SEARCH_MATCH_LIMIT=20

# --- Email notifier (wysyłka na końcu pipeline run) ---
NOTIFIER_ENABLED=true
NOTIFIER_MAX_OFFERS=10
NOTIFIER_SECRET=zmien-na-losowy-sekret-min-16-znakow

# Amazon SES SMTP (region eu-central-1) — po weryfikacji tożsamości w SES
# SMTP_HOST=email-smtp.eu-central-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=<ACCESS_KEY_ID z SMTP credentials SES>
# SMTP_PASSWORD=<SMTP password z SES>
# SMTP_FROM=jobsearch@twoja-domena.pl
# SMTP_TO=twoj-email@gmail.com
# SMTP_USE_TLS=true

# Tymczasowo Gmail (testy przed SES):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true

MIN_SEMANTIC_SCORE=0.65
MIN_LLM_CONFIDENCE=0.70
LOG_API_QUOTA=true

SCRAPER_USER_AGENT=JobSearchBot/1.0 (+https://github.com/Maxifunny/Job_search)
SCRAPER_REQUEST_DELAY_SECONDS=2
