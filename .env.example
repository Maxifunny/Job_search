# Application
APP_ENV=development
LOG_LEVEL=INFO

# Relational database (SQLite default; PostgreSQL for production)
DATABASE_URL=sqlite:///./data/job_search.db
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/job_search

# Vector database (ChromaDB)
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_OFFERS=job_offers
CHROMA_COLLECTION_PREFERENCES=user_preferences

# LLM provider (OpenAI-compatible API)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_FALLBACK_MODELS=gpt-4o-mini,gpt-3.5-turbo
LLM_RETRY_ATTEMPTS=2
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_FALLBACK_MODELS=text-embedding-3-small
# Log token usage + remaining quota headers (if provider exposes them)
LOG_API_QUOTA=true

# Matching thresholds
MIN_SEMANTIC_SCORE=0.65
MIN_LLM_CONFIDENCE=0.70

# Scraper settings
SCRAPER_USER_AGENT=JobSearchBot/1.0 (+https://github.com/Maxifunny/Job_search)
SCRAPER_REQUEST_DELAY_SECONDS=2
JUSTJOIN_API_BASE=https://justjoin.it/api/candidate-api
PRACUJ_PL_BASE_URL=https://www.pracuj.pl
NOFLUFFJOBS_API_BASE=https://nofluffjobs.com/api
LINKEDIN_GUEST_API_BASE=https://www.linkedin.com/jobs-guest/jobs/api/seeMoreJobPostings/search
LINKEDIN_JOBS_LOCATION=Poland
SCRAPER_MAX_PAGES=3
SCRAPER_ITEMS_PER_PAGE=50
SCRAPER_MAX_OFFERS_PER_QUERY=30
